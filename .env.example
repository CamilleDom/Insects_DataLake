# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# PostgreSQL Configuration
POSTGRES_USER=insect_user
POSTGRES_PASSWORD=insect_pass
POSTGRES_DB=insect_lake

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# iNaturalist API (optional, increases rate limit)
INATURALIST_API_KEY=

# Data Sources
INATURALIST_PLACE_ID=6753  # France
INATURALIST_TAXON_ID=47158  # Insecta
GBIF_DATASET_URL=https://www.gbif.org/occurrence/download

# Airflow Configuration
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=false
